</span><span>    registry = load_registry("nautilus.json")
</span><span>    adapters = instantiate_adapters(registry, filter=target_repos)
</span><span>    
</span><span>    # параллельный вызов fetch — каждый адаптер работает независимо
</span><span>    results_by_repo = parallel_fetch(adapters, user_query)
</span><span>    
</span><span>    # вычисление consensus
</span><span>    consensus = compute_consensus(results_by_repo)
</span><span>    
</span><span>    return QueryResult(
</span><span>        query=user_query,
</span><span>        results_by_repo=results_by_repo,
</span><span>        consensus=consensus,
</span><span>        total_entries=sum(len(r) for r in results_by_repo.values()),
</span><span>        repos_queried=[a.name for a in adapters]
</span><span>    )
