</span></span><span><span class="token token code code-block language-json">  </span><span class="token token code code-block language-json" style="color: rgb(184, 10, 24);">"repositories"</span><span class="token token code code-block language-json" style="color: rgb(20, 24, 31);">:</span><span class="token token code code-block language-json"> </span><span class="token token code code-block language-json" style="color: rgb(43, 48, 59);">[</span><span class="token token code code-block language-json">
