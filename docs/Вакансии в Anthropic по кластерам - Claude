</span><span>def compute_consensus(results_by_repo: dict[str, list[PortalEntry]]) -&gt; Consensus:
</span><span>    """
</span><span>    Вычисление consensus между репо.
</span><span>    
</span><span>    Стратегия v1.0: простая string-similarity по заголовкам.
</span><span>    В v2.0: semantic similarity через embeddings.
</span><span>    """
</span><span>    
</span><span>    all_concepts = set()
</span><span>    for entries in results_by_repo.values():
</span><span>        for e in entries:
</span><span>            all_concepts.add(normalize(e.title))
</span><span>    
</span><span>    concept_coverage = {}  # concept → {список репо, где найден}
</span><span>    for concept in all_concepts:
</span><span>        for repo, entries in results_by_repo.items():
</span><span>            if any(similar(concept, normalize(e.title)) for e in entries):
</span><span>                concept_coverage.setdefault(concept, []).append(repo)
</span><span>    
</span><span>    total_repos = len(results_by_repo)
</span><span>    
</span><span>    full_consensus = [c for c, repos in concept_coverage.items() if len(repos) == total_repos]
</span><span>    partial_consensus = [(c, repos) for c, repos in concept_coverage.items() 
</span><span>                         if 1 &lt; len(repos) &lt; total_repos]
</span><span>    singular = [(c, repos[0]) for c, repos in concept_coverage.items() if len(repos) == 1]
</span><span>    
</span><span>    return Consensus(
</span><span>        full=full_consensus,
</span><span>        partial=partial_consensus,
</span><span>        singular=singular,
</span><span>        coverage_ratio=len(full_consensus) / max(len(all_concepts), 1)
</span><span>    )</span></code></pre></div></div>
