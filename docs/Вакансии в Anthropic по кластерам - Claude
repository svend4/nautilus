</span></span><span><span class="token token code code-block language-json">      </span><span class="token token code code-block language-json" style="color: rgb(184, 10, 24);">"bridges"</span><span class="token token code code-block language-json" style="color: rgb(20, 24, 31);">:</span><span class="token token code code-block language-json"> </span><span class="token token code code-block language-json" style="color: rgb(43, 48, 59);">{</span><span class="token token code code-block language-json">
</span></span><span><span class="token token code code-block language-json">        </span><span class="token token code code-block language-json" style="color: rgb(184, 10, 24);">"other_repo_name"</span><span class="token token code code-block language-json" style="color: rgb(20, 24, 31);">:</span><span class="token token code code-block language-json"> </span><span class="token token code code-block language-json" style="color: rgb(0, 128, 0);">"string (bridge description)"</span><span class="token token code code-block language-json">
</span></span><span><span class="token token code code-block language-json">      </span><span class="token token code code-block language-json" style="color: rgb(43, 48, 59);">}</span><span class="token token code code-block language-json">
</span></span><span><span class="token token code code-block language-json">    </span><span class="token token code code-block language-json" style="color: rgb(43, 48, 59);">}</span><span class="token token code code-block language-json">
</span></span><span><span class="token token code code-block language-json">  </span><span class="token token code code-block language-json" style="color: rgb(43, 48, 59);">]</span><span class="token token code code-block language-json">
