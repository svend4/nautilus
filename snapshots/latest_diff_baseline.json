    "pro2:bidir": {
      "id": "pro2:bidir",
      "title": "Bidirectional Training ⇑⇓ (замкнутый цикл)",
      "content": "ВПЕРЁД (специализация→обобщение): Корпус→KnowledgeGraph→PageRank-центры→Q6-анкоры→Variant3GPT. НАЗАД (обобщение→специализация): GPT генерирует→QFilter оценивает→AdaptiveLearning обновляет граф→identify_gaps()→generate_hypotheses()→новый корпус→снова вперёд. Реализует НЕДОСТАЮЩУЮ ПЕТЛЮ из data7/knowl",
      "source": "svend4/pro2",
      "format_type": "concept",
      "q6": "",
      "links": [
        "data7:missing_loop",
        "data7:theory:transformation",
        "info1:methodology"
      ],
      "is_fallback": true
    },
    "pro2:knowledge_graph": {
      "id": "pro2:knowledge_graph",
      "title": "KnowledgeGraph — граф научных знаний",
      "content": "Аналог data7:KnowledgeGraph. Отличие: рёбра взвешены качеством связи (обновляется AdaptiveLearning). Типы рёбер: causes, extends, contradicts, related_to, is_a, part_of. PageRank-центральность определяет Q6-анкоры для обучения.",
      "source": "svend4/pro2",
      "format_type": "concept",
