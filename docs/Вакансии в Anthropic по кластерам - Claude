.voice-visualizer__buttons-container { display: flex; justify-content: center; align-items: center; gap: 15px 20px; flex-wrap: wrap; margin-bottom: 40px; }

.voice-visualizer__btn-center { box-sizing: border-box; flex-shrink: 0; width: 60px; height: 60px; padding: 0px; display: flex; justify-content: center; align-items: center; border-radius: 50%; background-color: rgb(255, 255, 255); border: 4px solid rgb(197, 197, 197); outline: none; cursor: pointer; transition: border-color 0.3s, background-color 0.3s; }

.voice-visualizer__btn-center:disabled { opacity: 0.85; cursor: default; }

.voice-visualizer__btn-center:hover { background-color: rgb(234, 234, 234); border: 4px solid rgb(159, 159, 159); }

.voice-visualizer__btn-center > img { width: auto; height: 50%; max-height: 30px; }

.voice-visualizer__btn-center.voice-visualizer__btn-center-pause { background-color: rgb(255, 48, 48); }

.voice-visualizer__btn-center.voice-visualizer__btn-center-pause:hover { background-color: rgb(255, 79, 79); }

.voice-visualizer__btn-center.voice-visualizer__btn-center-pause > img { height: 50%; max-height: 16px; }

.voice-visualizer__btn-center.voice-visualizer__btn-center--border-transparent { border-color: transparent; }

.voice-visualizer__btn-center.voice-visualizer__btn-center--border-transparent:hover { background-color: rgb(255, 255, 255); }

.voice-visualizer__btn-left { box-sizing: border-box; flex-shrink: 0; width: 60px; height: 60px; padding: 0px; display: flex; justify-content: center; align-items: center; border-radius: 50%; background-color: rgb(255, 48, 48); border: 4px solid rgb(197, 197, 197); outline: none; cursor: pointer; transition: border-color 0.3s, background-color 0.3s, opacity 0.3s; }

.voice-visualizer__btn-container { min-width: 100px; display: flex; justify-content: flex-end; }

.voice-visualizer__btn-left:hover { background-color: rgb(255, 79, 79); }

.voice-visualizer__btn-left:disabled { opacity: 0.6; background-color: rgb(255, 48, 48); cursor: default; }

.voice-visualizer__btn-left.voice-visualizer__btn-left-microphone { background-color: rgb(255, 255, 255); }

.voice-visualizer__btn-left.voice-visualizer__btn-left-microphone > img { width: auto; height: 50%; max-height: 30px; }

.voice-visualizer__btn-left > img { width: auto; height: 50%; max-height: 16px; }

.voice-visualizer__btn-left:hover { border: 4px solid rgb(159, 159, 159); }

.voice-visualizer__btn { box-sizing: border-box; min-width: 100px; min-height: 60px; padding: 5px 20px; border-radius: 40px; font-size: 15px; background-color: rgb(240, 240, 240); transition: background-color 0.3s, opacity 0.3s; }

.voice-visualizer__btn:disabled { opacity: 0.8; background-color: rgb(240, 240, 240); cursor: default; }

.voice-visualizer__btn:hover { background-color: rgb(190, 190, 190); }

.voice-visualizer__canvas-container { position: relative; width: fit-content; margin: 0px auto; overflow: hidden; }

.voice-visualizer__canvas-container canvas { display: block; }

.voice-visualizer__canvas-microphone-btn { position: absolute; top: 50%; left: 50%; width: auto; max-width: 12%; min-width: 24px; height: 50%; max-height: 100px; background-color: transparent; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; outline: none; transform: translate(-50%, -50%); }

.voice-visualizer__canvas-microphone-icon { width: 100%; height: 100%; will-change: transform; transition: transform 0.3s; }

.voice-visualizer__canvas-microphone-btn:hover .voice-visualizer__canvas-microphone-icon { transform: scale(1.03); }

.voice-visualizer__canvas-audio-wave-icon { position: absolute; top: 50%; left: 50%; width: auto; max-width: 40%; height: 40%; max-height: 100px; transform: translate(-118%, -50%) scale(-1); }

.voice-visualizer__canvas-audio-wave-icon2 { transform: translate(18%, -50%); }

.voice-visualizer__canvas-audio-processing { position: absolute; top: 50%; left: 50%; margin: 0px; transform: translate(-50%, -50%); }

.voice-visualizer__progress-indicator-hovered { position: absolute; top: 0px; pointer-events: none; height: 100%; width: 1px; background-color: rgba(133, 133, 133, 0.6); }

.voice-visualizer__progress-indicator-hovered-time { position: absolute; top: 3%; left: 1px; width: fit-content; margin: 0px; padding: 0px 7px; opacity: 0.8; font-size: 12px; border-radius: 0px 4px 4px 0px; background-color: rgb(87, 87, 87); text-align: left; }

.voice-visualizer__progress-indicator-hovered-time.voice-visualizer__progress-indicator-hovered-time-left { left: unset; right: 1px; border-radius: 4px 0px 0px 4px; }

.voice-visualizer__progress-indicator { position: absolute; top: 0px; pointer-events: none; height: 100%; width: 1px; background-color: rgb(239, 239, 239); }

.voice-visualizer__progress-indicator-time { position: absolute; top: 3%; left: 1px; width: fit-content; box-sizing: border-box; min-width: 37px; margin: 0px; padding: 0px 7px; font-size: 12px; border-radius: 0px 4px 4px 0px; text-align: left; color: rgb(0, 0, 0); font-weight: 500; background-color: rgb(239, 239, 239); }

.voice-visualizer__progress-indicator-time.voice-visualizer__progress-indicator-time-left { left: unset; right: 1px; border-radius: 4px 0px 0px 4px; }

.voice-visualizer__audio-info-container { box-sizing: border-box; height: 55px; display: flex; align-items: center; justify-content: center; gap: 30px; }

.voice-visualizer__audio-info-time { margin: 15px 0px; min-width: 38px; text-align: left; }

.voice-visualizer__visually-hidden { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0px; border: 4px solid rgb(197, 197, 197); white-space: nowrap; clip-path: inset(100%); clip: rect(0px, 0px, 0px, 0px); overflow: hidden; }

.voice-visualizer__relative { position: relative; }

.voice-visualizer__spinner-wrapper { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 52px; height: 52px; display: flex; justify-content: center; align-items: center; }

.voice-visualizer__spinner { flex-shrink: 0; width: 100%; height: 100%; border-width: 4px; border-style: solid; border-color: rgb(183, 183, 183) rgba(197, 197, 197, 0.5) rgba(197, 197, 197, 0.5); border-image: initial; border-radius: 50%; animation: 1s ease-in-out 0s infinite normal none running voice-visualizer__spin; }

@keyframes voice-visualizer__spin { 
  100% { transform: rotate(360deg); }
}

@-webkit-keyframes voice-visualizer__spin { 
  100% { transform: rotate(360deg); }
}
